{
  "appId": "com.match.chat",
  "appName": "\u0645\u062f\u0627\u0631\u0643 \u0627\u0644\u062a\u0639\u0644\u064a\u0645\u064a\u0629",
  "webDir": "www",

  "server": {
    "androidScheme": "https",
    "iosScheme": "https",
    "allowNavigation": ["http://192.168.5.1:3000", "ws://192.168.5.1:3000"]
  },

  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false,
    "backgroundColor": "#0b1629",
    "overrideUserAgent": "MadarikApp/1.0 Android"
  },

  "ios": {
    "allowsLinkPreview": false,
    "scrollEnabled": true,
    "backgroundColor": "#0b1629",
    "overrideUserAgent": "MadarikApp/1.0 iOS",
    "contentInset": "automatic",
    "usesFonts": true
  },

  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2500,
      "launchAutoHide": true,
      "launchFadeOutDuration": 300,
      "backgroundColor": "#0b1629",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "iosSpinnerStyle": "large",
      "spinnerColor": "#4e8cff",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0b1629",
      "overlaysWebView": false
    },
    "Filesystem": {
      "iosSchemeName": "capacitor"
    }
  }
}
