{
  "env": {
    "browser": true,
    "es6": true,
    "node": true,
    "serviceworker": true
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "script"
  },
  "globals": {
    "APP_CONFIG": "readonly",
    "Auth": "readonly",
    "Modals": "readonly",
    "Chat": "readonly",
    "App": "readonly",
    "Navbar": "readonly",
    "Pages": "readonly",
    "Storage": "readonly",
    "Utils": "readonly",
    "Theme": "readonly",
    "UserRegistry": "readonly",
    "Friends": "readonly",
    "Groups": "readonly",
    "RBAC": "readonly",
    "Reports": "readonly",
    "AuditLog": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "args": "none" }],
    "no-undef": "error",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "eqeqeq": ["warn", "smart"],
    "curly": ["warn", "multi-line"],
    "no-var": "off",
    "semi": ["warn", "always"],
    "no-alert": "off",
    "no-console": "off"
  },
  "ignorePatterns": ["www/", "android/", "node_modules/"]
}
