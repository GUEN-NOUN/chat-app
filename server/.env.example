# ═══════════════════════════════════════════════════════════════════════════════
# Madarik Server — Environment Variables
# Copy this file to server/.env and fill in your values.
# In production: set these as real environment variables (not in a .env file).
# ═══════════════════════════════════════════════════════════════════════════════

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── JWT — REQUIRED in production ─────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET

# ── Admin account (first run only — override the default seed) ────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ── CORS — comma-separated list of allowed origins ───────────────────────────
# Example: https://madarik.com,https://www.madarik.com
ALLOWED_ORIGINS=https://yourdomain.com

# ── Site URL (used in API HTTP-Referer headers) ───────────────────────────
SITE_URL=https://yourdomain.com

# ── AI API Keys ───────────────────────────────────────────────────────────────
# OpenAI (for agent-gpt): https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter (free AI models — recommended): https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Optional: Redis for multi-instance Socket.io scaling ─────────────────────
# REDIS_URL=redis://localhost:6379
