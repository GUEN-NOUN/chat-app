# ─────────────────────────────────────────────────────
# Madarik Chat App — Environment Variables
# Copy this file to .env (never commit .env to git!)
# ─────────────────────────────────────────────────────

# HTTP server port (default: 3000)
PORT=3000

# Node environment: development | production
NODE_ENV=development

# JWT signing secret — REQUIRED in production.
# Generate a strong secret:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_in_production

# Allowed CORS origins in production (comma-separated)
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=

# Redis connection URL (optional — for multi-instance scaling)
# Example: REDIS_URL=redis://localhost:6379
REDIS_URL=

# AI providers (optional)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Admin seed account (optional — created on first startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
