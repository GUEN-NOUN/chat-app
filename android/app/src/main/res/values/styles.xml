<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Base application theme.
        The parent uses DayNight so the system tells us light/dark,
        but we always override with our dark brand colours (set in colors.xml).
    -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <!-- Ensure the WebView background matches before assets load -->
        <item name="android:windowBackground">@color/windowBackground</item>
    </style>

    <!-- Used for non-WebView screens (dialogs, etc.) -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
    </style>

    <!--
        Splash-screen theme (Android 12+ SplashScreen API).
        android:background is the full-screen colour shown before the window
        is drawn; we use the dark navy to prevent a white flash.
        The postSplashScreenTheme switches back to AppTheme once the splash
        is dismissed.
    -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <!-- Colour of the circular window inset splash background (API 31+) -->
        <item name="windowSplashScreenBackground">@color/splashBackground</item>
        <!-- Icon shown in the center of the API-31 splash window -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <!-- Theme applied after the splash is dismissed -->
        <item name="postSplashScreenTheme">@style/AppTheme</item>
    </style>

</resources>